# ─── Dart / Flutter ───────────────────────────────────────────────────────────
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/
**/doc/api/
**/ios/Flutter/.last_build_id

# ─── Signing & secrets ────────────────────────────────────────────────────────
# Keystore files — never commit; losing these means losing the signing identity
*.jks
*.keystore
*.p12
*.pem

# Key property files containing passwords
android/key.properties
ios/Runner/GoogleService-Info.plist

# Firebase / Google config (contain API keys)
google-services.json
GoogleService-Info.plist

# Generic secret / env files
.env
.env.*
*.env
*.secret
secrets.dart
secrets.json
secrets.yaml
secrets.yml

# ─── Android ──────────────────────────────────────────────────────────────────
# Local machine paths (sdk.dir, flutter.sdk) — different on every machine
android/local.properties

# Android Studio build outputs
/android/app/debug/
/android/app/profile/
/android/app/release/
/android/.gradle/
/android/captures/
/android/gradlew
/android/gradlew.bat

# ─── iOS ──────────────────────────────────────────────────────────────────────
**/ios/**/*.mode1v3
**/ios/**/*.mode2v3
**/ios/**/*.moved-aside
**/ios/**/*.pbxuser
**/ios/**/*.perspectivev3
**/ios/**/UserInterfaceState.xcuserstate
**/ios/.generated/
**/ios/Flutter/App.framework
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Flutter.podspec
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/ephemeral/
**/ios/Flutter/app.flx
**/ios/Flutter/app.zip
**/ios/Flutter/flutter_assets/
**/ios/ServiceDefinitions.json
**/ios/Runner/GeneratedPluginRegistrant.*
ios/Pods/

# ─── Obfuscation & crash symbols ──────────────────────────────────────────────
# Needed only to decode obfuscated stack traces — store separately, not in repo
app.*.symbols
app.*.map.json
build/symbols/

# ─── IDEs & editors ───────────────────────────────────────────────────────────
.idea/
*.iml
*.ipr
*.iws
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ─── Logs & temp ──────────────────────────────────────────────────────────────
*.log
*.class
*.pyc
.history
.atom/
.build/
.buildlog/
.svn/
.swiftpm/
migrate_working_dir/
